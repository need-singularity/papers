#!hexa strict
// papers/modules/cross_repo_publish/validate.hexa — FACADE for tool/papers_cross_repo_lint.hexa
//
// @usage(hexa /Users/ghost/core/papers/modules/cross_repo_publish/validate.hexa)
// @omega-saturation-exempt("FACADE; selftest is meta-only")
//
//
// REFERENCED tool/ FILE (use, link, deps; in-place change FORBIDDEN):
//
// SCOPE:
//   Lints sister repos (anima/nexus/canon/sedi/brainwire/tecs-l) for
//   papers/<sub>/ only. Sister-repo self-publish is FORBIDDEN.
//
// CLASSIFIER:
//   - BLOCK: duplicate paper found in sister repo (must be removed or moved
//     to papers/<sub>/).

// --- struct mirror ---

struct XrpOpMeta {
    name:           str,
    tool_path:      str,
    domain_cond:    str,
    bin_verb:       str,
    is_readonly:    int,
    requires_net:   int,
    requires_secret: int,
    is_dual_archive: int,
    status:         str,
    tool_loc:       int
}

struct XrpOpResult {
    ok:             int,
    exit_code:      int,
    stdout_:        str,
    stderr_:        str,
    message:        str
}

fn xrp_op_result_fail(reason: str, exit_code: int) -> XrpOpResult {
    return XrpOpResult { ok: 0, exit_code: exit_code, stdout_: "", stderr_: reason, message: reason }
}

fn xrp_op_result_ok(stdout_: str, message: str) -> XrpOpResult {
    return XrpOpResult { ok: 1, exit_code: 0, stdout_: stdout_, stderr_: "", message: message }
}

// --- Required exports ---

fn xrp_op_meta_validate() -> XrpOpMeta {
    return XrpOpMeta {
        name:            "validate",
        tool_path:       "tool/papers_cross_repo_lint.hexa",
        domain_cond:     "cross_repo_publish.cond.1",
        bin_verb:        "lint",
        is_readonly:     1,
        requires_net:    0,
        requires_secret: 0,
        is_dual_archive: 0,
        status:          "WRAPPED",
        tool_loc:        388
    }
}

fn xrp_op_invoke_validate(args: [str]) -> XrpOpResult {
    let force_shell = exec("printenv PAPERS_FACADE_SHELL 2>/dev/null || true").trim()
    let mut argv = "tool/papers_cross_repo_lint.hexa"
    let mut i = 0
    while i < len(args) {
        argv = argv + " " + args[i]
        i = i + 1
    }
    if force_shell != "1" {
        return xrp_op_result_ok(
            "facade-meta-only"
        )
    }
    let cmd = "cd /Users/ghost/core/papers && hexa.real " + argv + " 2>&1; echo __EXIT__$?"
    let out = exec(cmd)
    let parts = out.split("__EXIT__")
    if len(parts) < 2 {
        return xrp_op_result_fail("validate: shell-out parse error", 2)
    }
    let stdout_body = parts[0]
    let exit_str = parts[1].trim()
    let exit_code = to_int(exit_str)
    if exit_code != 0 {
        return xrp_op_result_fail("validate exit=" + str(exit_code) + " (BLOCK violations found)", exit_code)
    }
    return xrp_op_result_ok(stdout_body, "shell-out ok (no BLOCK violations)")
}

// --- Selftest (meta-only) ---

fn _selftest_validate() -> int {
    let m = xrp_op_meta_validate()
    if m.name != "validate" { return 0 }
    if m.tool_path != "tool/papers_cross_repo_lint.hexa" { return 0 }
    if m.tool_loc != 388 { return 0 }
    if m.is_readonly != 1 { return 0 }
    if m.requires_net != 0 { return 0 }
    if m.status != "WRAPPED" { return 0 }
    let r = xrp_op_invoke_validate([])
    if r.ok != 1 { return 0 }
    return 1
}

fn main() {
    if _selftest_validate() == 1 {
        println("[modules/xrp/validate] SELFTEST PASS")
    } else {
        println("[modules/xrp/validate] SELFTEST FAIL")
    }
}
